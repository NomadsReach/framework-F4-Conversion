{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/external/commonlibsse-ng/include",
                "${workspaceFolder}/build/external_builds/ultralight/include",
                "${workspaceFolder}/build/vcpkg_installed/x64-windows-static/include",
                "${workspaceFolder}/build/release/_deps/**",
                "${vcpkgRoot}/installed/x64-windows-static/include"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "WIN32_LEAN_AND_MEAN",
                "NOMINMAX",
                "WINVER=0x0A00",
                "_WIN32_WINNT=0x0A00",
                "SKSE_SUPPORT_XBYAK",
                "ENABLE_SKYRIM_AE",
                "ENABLE_SKYRIM_SE"
            ],
            "windowsSdkVersion": "10.0.22621.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "intelliSenseMode": "windows-msvc-x64",
            "compileCommands": "${workspaceFolder}/build/release/compile_commands.json",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}
